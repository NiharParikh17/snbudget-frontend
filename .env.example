# Base URL of the SNBudget API gateway. Defaults to http://localhost:8080
# when the variable is not set. All service endpoints (identity, budgets,
# etc.) are reached through the gateway — basepaths are unchanged.
# The gateway must allow this origin and send
# `Access-Control-Allow-Credentials: true` because the frontend uses
# `credentials: 'include'` so the HttpOnly refresh cookie can be sent.
VITE_API_BASE_URL=http://localhost:8080

